QCheckBox {
    color: [[fg_dim]];
    font-size: 10px;
    spacing: 6px;
    background: transparent;
}
QCheckBox::indicator {
    width: 13px;
    height: 13px;
    border-radius: 4px;
    border: 1px solid [[outline_soft]];
    background: [[surface_panel]];
}
QCheckBox::indicator:checked {
    background: [[accent_soft]];
    border-color: [[accent_border]];
}
