QSlider::groove:horizontal {
    background: [[slider_track]];
    height: 4px;
    border-radius: 2px;
}
QSlider::sub-page:horizontal {
    background: [[accent]];
    border-radius: 2px;
}
QSlider::add-page:horizontal {
    background: [[slider_track]];
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: [[slider_handle]];
    width: 11px;
    height: 11px;
    margin: -4px 0;
    border-radius: 5px;
}
QSlider::handle:horizontal:hover { background: [[slider_hover]]; }
