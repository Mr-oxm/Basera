[[selector]] {
    background-color: [[bg]];
    color: [[fg]];
    font-family: 'Segoe UI', sans-serif;
    font-size: [[font_size]]px;
}
[[selector]] QLabel {
    color: [[label_fg]];
    background: transparent;
}
[[row_selector]] {
    background-color: transparent;
    border-radius: [[row_radius]]px;
}
[[row_selector]]:hover {
    background-color: [[row_hover]];
}
