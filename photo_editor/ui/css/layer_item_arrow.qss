QPushButton {
	font-family: "Segoe UI Symbol", "Segoe UI Variable Text", "Aptos", sans-serif;
	font-size: 11px;
	font-weight: 600;
	padding: 0px;
	color: [[fg_dim]];
	background: transparent;
	border: 1px solid transparent;
	border-radius: 8px;
}

QPushButton:hover {
	color: [[fg]];
	background: [[surface_hover]];
	border-color: [[outline_soft]];
}

QPushButton:pressed {
	color: [[fg]];
	background: [[surface_pressed]];
	border-color: [[outline_strong]];
}
