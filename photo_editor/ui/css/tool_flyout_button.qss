QToolButton {
    text-align: left;
    padding: 5px 8px;
    color: [[fg]];
    background: transparent;
    border: 1px solid transparent;
    border-radius: 8px;
}
QToolButton:hover {
    background: [[surface_hover]];
    border-color: [[outline_soft]];
}
QToolButton:checked {
    background: [[accent_soft]];
    color: [[fg]];
    border-color: [[accent_border]];
}
